\n","GDRIVE_PATH         = '/content/drive/MyDrive/DoAn_DaLieu'\n","DATA_TEST_PATH      = os.path.join(GDRIVE_PATH, \"1_Data\", \"Data_test\")\n","EXTERNAL_TEST_PATH  = os.path.join(GDRIVE_PATH, \"7_External_Test\")\n","RESULTS_FOLDER      = os.path.join(EXTERNAL_TEST_PATH, \"results\")\n","EXTERNAL_CSV        = os.path.join(EXTERNAL_TEST_PATH, \"external_test.csv\")\n","\n","os.makedirs(EXTERNAL_TEST_PATH, exist_ok=True)\n","os.makedirs(RESULTS_FOLDER, exist_ok=True)\n","\n","print(f\"\\n✅ DATA_TEST_PATH: {DATA_TEST_PATH}\")\n","print(f\"✅ RESULTS_FOLDER: {RESULTS_FOLDER}\")\n","\n","\n","def estimate_image_quality(image):\n","    gray = cv2.cvtColor(image, cv2.COLOR_RGB2GRAY)\n","    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (17, 17))\n","    blackhat = cv2.morphologyEx(gray, cv2.MORPH_BLACKHAT, kernel)\n","    hair_pixels = np.sum(blackhat > 10)\n","    hair_ratio = hair_pixels / gray.size\n","    hair_score = 1.0 - min(hair_ratio / 0.05, 1.0)\n","\n","    h, w = gray.shape\n","    grid_size = 8\n","    cell_h, cell_w = h // grid_size, w // grid_size\n","    cell_means = []\n","    for i in range(grid_size):\n","        for j in range(grid_size):\n","            cell = gray[i*cell_h:(i+1)*cell_h, j*cell_w:(j+1)*cell_w]\n","            cell_means.append(cell.mean())\n","    shadow_variance = np.std(cell_means) / 255.0\n","    shadow_score = 1.0 - min(shadow_variance / 0.2, 1.0)\n","\n","    laplacian_var = cv2.Laplacian(gray, cv2.CV_64F).var()\n","    sharpness_score = min(laplacian_var / 500.0, 1.0)\n","\n","    median_filtered = cv2.medianBlur(gray, 5)\n","    noise_map = np.abs(gray.astype(np.float32) - median_filtered.astype(np.float32))\n","    noise_level = noise_map.mean()\n","    noise_score = 1.0 - min(noise_level / 20.0, 1.0)\n","\n","    quality_score = (\n","        hair_score * 0.35 +\n","        shadow_score * 0.30 +\n","        sharpness_score * 0.20 +\n","        noise_score * 0.15\n","    )\n","\n","    issues = []\n","    if hair_score < 0.6: issues.append('hair')\n","    if shadow_score < 0.6: issues.append('shadow')\n","    if sharpness_score < 0.5: issues.append('blur')\n","    if noise_score < 0.6:\n","        issues.append('noise')\n","        print(\"⚠️ High noise detected in image\")\n","        quality_score *= 0.8\n","\n","    quality_details = {\n","        'hair_score': float(hair_score),\n","        'shadow_score': float(shadow_score),\n","        'sharpness_score': float(sharpness_score),\n","        'noise_score': float(noise_score),\n","        'overall': float(quality_score)\n","    }\n","    return quality_score, quality_details, issues\n","\n","\n","print(\"✅ estimate_image_quality defined (FIXED with noise)\")\n","\n","\n","def estimate_mask_quality(mask_pred):\n","    \"\"\"\n","    Ước lượng chất lượng mask OUTPUT\n","\n","    Args:\n","        mask_pred: numpy array (H, W), [0, 1]\n","\n","    Returns:\n","        quality_score: float [0, 1]\n","        quality_info: dict\n","    \"\"\"\n","    mask = np.clip(mask_pred, 0, 1).astype(np.float32)\n","    mask_area = (mask > 0.5).sum()\n","    total_area = mask.size\n","    coverage = mask_area / total_area\n","    coverage_score = 0.3 if (coverage < 0.02 or coverage > 0.6) else 1.0\n","    confidence_map = np.abs(mask - 0.5)\n","    avg_confidence = confidence_map.mean() * 2\n","    quality_score = coverage_score * 0.4 + avg_confidence * 0.6\n","    quality_info = {\n","        'coverage': float(coverage),\n","        'confidence': float(avg_confidence),\n","        'overall': float(quality_score)\n","    }\n","    return quality_score, quality_info\n","# ==============================================================================\n","# TẠO LẠI CSV MỚI TỪ FOLDER Data_test (ĐẢM BẢO KHỚP VỚI NỘI DUNG HIỆN TẠI)\n","# ==============================================================================\n","\n","def create_external_csv(data_test_path, output_csv):\n","    \"\"\"\n","    Tạo file CSV external_test.csv từ nội dung trong folder Data_test.\n","\n","    Args:\n","        data_test_path (str): Đường dẫn đến folder Data_test.\n","        output_csv (str): Đường dẫn lưu file CSV kết quả.\n","\n","    Returns:\n","        pd.DataFrame: DataFrame chứa thông tin từ folder Data_test.\n","    \"\"\"\n","    rows = []  # Danh sách các hàng cho file CSV\n","    classes = ['AKIEC', 'BCC', 'BKL', 'DF', 'MEL', 'NV', 'VASC']  # Các class hợp lệ\n","\n","    for cls in classes:\n","        folder_path = os.path.join(data_test_path, cls)\n","        if not os.path.isdir(folder_path):\n","            print(f\"⚠️ Folder not found: {cls}. Skipping...\")\n","            continue\n","\n","        for img_name in os.listdir(folder_path):\n","            if img_name.lower().endswith(('.jpg', '.jpeg', '.png', '.bmp', '.tiff', '.tif', '.webp')):\n","                rows.append({\n","                    'image_name': img_name,\n","                    'ground_truth': cls,\n","                    'source': 'ExternalTest',\n","                    'note': ''\n","                })\n","                image_path = os.path.join(folder_path, img_name)\n","\n","            # Kiểm tra chất lượng ảnh và loại bỏ ảnh kém\n","            def is_quality_acceptable(image_path):\n","                image = cv2.imread(image_path)\n","                if image is None:\n","                    return False\n","                image_quality, _, _ = estimate_image_quality(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))\n","                return image_quality >= 0.3  # Ngưỡng tối thiểu 0.3 cho chất lượng ảnh\n","\n","            if not is_quality_acceptable(image_path):\n","                print(f\"❌ Skipping low-quality image: {img_name} (below threshold)\")\n","                continue\n","\n","    if rows:\n","        df = pd.DataFrame(rows)\n","        df.to_csv(output_csv, index=False)\n","        print(f\"✅ CSV created: {output_csv}\")\n","        print(\"\\n📊 Class distribution:\")\n","        print(df['ground_truth'].value_counts())\n","        return df\n","    else:\n","        print(\"❌ No valid images found in Data_test. Please check folder structure.\")\n","        return None\n","\n","# Tạo lại file CSV mới dựa trên nội dung từ Data_test\n","df = create_external_csv(DATA_TEST_PATH, EXTERNAL_CSV)\n","\n","# Hiển thị thông tin mới sau khi tạo CSV\n","if df is not None:\n","    print(\"\\n👉 CSV Overview:\")\n","    print(f\"🔸 Total images: {len(df)}\")\n","    print(df['ground_truth'].value_counts())\n","else:\n","    print(\"❌ Failed to create CSV! Check folder content.\")\n","\n","# ==============================================================================\n","# KIỂM TRA FILE CSV & FOLDER\n","# ==============================================================================\n","\n","if df is not None and not df.empty:\n","    missing_files = []\n","    for idx, row in df.iterrows():\n","        file_path = os.path.join(DATA_TEST_PATH, row['ground_truth'], row['image_name'])\n","        if not os.path.exists(file_path):\n","            missing_files.append(file_path)\n","\n","    if missing_files:\n","        print(f\"❌ Missing files: {len(missing_files)}\")\n","        for file in missing_files[:5]:\n","            print(f\"Missing: {file}\")\n","        assert False, \"Please fix missing files and rerun.\"\n","    else:\n","        print(f\"✅ All files exist in the specified folders.\")\n","\n","# Load CSV nếu tồn tại\n","df = pd.read_csv(EXTERNAL_CSV)\n","print(\"👉 Overview:\")\n","print(f\"🔸 Total images: {len(df)}\")\n","print(df['ground_truth'].value_counts())"]},{"cell_type":"code","execution_count":21,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":52,"status":"ok","timestamp":1767519694718,"user":{"displayName":"Hương Giang Nguyễn","userId":"06423650985682136534"},"user_tz":-420},"id":"YpP-meV0Ijma","outputId":"932202b7-b7f3-44df-d2cb-fdd61fec971e"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","================================================================================\n","📦 LOADING PREPROCESSING UTILS\n","================================================================================\n","✅ Checkpoint loaded: 2025-12-16T11:01:22.991942\n","   Version: 1.1.0\n","✅ PreprocessingPipeline defined (FIXED)\n","✅ PostprocessingPipeline with smart mode defined\n","✅ Classes & helpers defined\n","   - Preprocessing presets: ['smartphone', 'smartphone_light', 'elderly_skin', 'clinic', 'clean']\n","   - Postprocessing presets: ['noisy', 'clean']\n","\n","================================================================================\n"]}],"source":["# ==============================================================================\n","# Ô 2: LOAD PREPROCESSING UTILS TỪ CHECKPOINT\n","# ==============================================================================\n","\n","print(\"\\n\" + \"=\"*80)\n","print(\"📦 LOADING PREPROCESSING UTILS\")\n","print(\"=\"*80)\n","\n","checkpoint_path = os.path.join(GDRIVE_PATH, \"3_Checkpoints\", \"10_preprocessing_utils_complete.json\")\n","\n","if not os.path.exists(checkpoint_path):\n","    print(f\"❌ Checkpoint not found:  {checkpoint_path}\")\n","    print(\"⚠️  Please run File 10 first!\")\n","    raise FileNotFoundError(checkpoint_path)\n","\n","with open(checkpoint_path, 'r', encoding='utf-8') as f:\n","    prep_config = json.load(f)\n","\n","print(f\"✅ Checkpoint loaded: {prep_config['timestamp']}\")\n","print(f\"   Version: {prep_config['version']}\")\n","\n","class PreprocessingPipeline:\n","    \"\"\"Pipeline tiền xử lý cho ảnh da xấu\"\"\"\n","    def __init__(self,\n","                 remove_hair=False,\n","                 reduce_shadow=False,\n","                 smooth_skin=False,\n","                 enhance_contrast=False,\n","                 clip_limit=2.0):  # ← THÊM\n","        self.remove_hair = remove_hair\n","        self.reduce_shadow = reduce_shadow\n","        self. smooth_skin = smooth_skin\n","        self.enhance_contrast = enhance_contrast\n","        self.clip_limit = clip_limit  # ← THÊM\n","\n","    def __call__(self, image):\n","        debug_info = {'original':  image. copy()}\n","        processed = image.copy()\n","        if self.remove_hair:\n","            processed = self._remove_hair(processed)\n","            debug_info['after_hair_removal'] = processed. copy()\n","        if self.reduce_shadow:\n","            processed = self._reduce_shadow(processed)\n","            debug_info['after_shadow_reduction'] = processed.copy()\n","        if hasattr(self, 'reduce_noise') and self.reduce_noise:\n","            # Giảm nhiễu:\n","            processed = reduce_noise(processed)\n","            debug_info['after_noise_reduction'] = processed.copy()\n","        if self.smooth_skin:\n","            processed = self._smooth_skin(processed)\n","            debug_info['after_smoothing'] = processed.copy()\n","        if self.enhance_contrast:\n","            processed = self._enhance_contrast(processed)\n","            debug_info['after_contrast'] = processed.copy()\n","        return processed, debug_info\n","\n","    def _remove_hair(self, image):\n","        \"\"\"\n","        Loại bỏ lông CÂN BẰNG - KHỚP VỚI FILE 10\n","\n","        Strategy:\n","        1. Kernel 13×13\n","        2. Threshold 12\n","        3. Inpaint radius 4\n","        4. Điều kiện 300 pixels\n","        \"\"\"\n","        gray = cv2.cvtColor(image, cv2.COLOR_RGB2GRAY)\n","\n","        # Kernel 13×13\n","        kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (13, 13))\n","        blackhat = cv2.morphologyEx(gray, cv2.MORPH_BLACKHAT, kernel)\n","\n","        # Threshold 12\n","        _, hair_mask = cv2.threshold(blackhat, 12, 255, cv2.THRESH_BINARY)\n","\n","        # Morphology clean\n","        kernel_clean = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))\n","        hair_mask = cv2.morphologyEx(hair_mask, cv2.MORPH_OPEN, kernel_clean)\n","\n","        # Điều kiện 300\n","        hair_pixels = np.sum(hair_mask > 0)\n","        if hair_pixels > 300:\n","            # Radius 4\n","            result = cv2.inpaint(image, hair_mask, inpaintRadius=4, flags=cv2.INPAINT_TELEA)\n","            return result\n","\n","        return image\n","\n","    def _reduce_shadow(self, image):\n","        \"\"\"\n","        Giảm bóng DYNAMIC - DÙNG self.clip_limit\n","        \"\"\"\n","        lab = cv2.cvtColor(image, cv2.COLOR_RGB2LAB)\n","        l, a, b = cv2.split(lab)\n","\n","        # ← DÙNG self.clip_limit\n","        clahe = cv2.createCLAHE(clipLimit=self.clip_limit, tileGridSize=(8, 8))\n","        l_clahe = clahe.apply(l)\n","\n","        lab_clahe = cv2.merge([l_clahe, a, b])\n","        result = cv2.cvtColor(lab_clahe, cv2.COLOR_LAB2RGB)\n","\n","        return result\n","\n","    def _smooth_skin(self, image):\n","        return cv2.bilateralFilter(image, d=9, sigmaColor=75, sigmaSpace=75)\n","\n","    def _enhance_contrast(self, image):\n","        lab = cv2.cvtColor(image, cv2.COLOR_RGB2LAB)\n","        l, a, b = cv2.split(lab)\n","        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))\n","        l_clahe = clahe.apply(l)\n","        lab_clahe = cv2.merge([l_clahe, a, b])\n","        return cv2.cvtColor(lab_clahe, cv2.COLOR_LAB2RGB)\n","\n","\n","print(\"✅ PreprocessingPipeline defined (FIXED)\")\n","\n","\n","class PostprocessingPipeline:\n","    \"\"\"Pipeline hậu xử lý cho mask\"\"\"\n","    def __init__(self,\n","             fill_holes=True,\n","             remove_small_objects=True,\n","             smooth_boundary=True,\n","             select_largest=True,\n","             min_object_size=500,\n","             smart_mode=True,  # ← THÊM\n","             distance_threshold=30):  # ← THÊM\n","        self.fill_holes = fill_holes\n","        self. remove_small_objects = remove_small_objects\n","        self.smooth_boundary = smooth_boundary\n","        self.select_largest = select_largest\n","        self.min_object_size = min_object_size\n","        self.smart_mode = smart_mode  # ← BỔ SUNG\n","        self.distance_threshold = distance_threshold  # ← BỔ SUNG\n","\n","    def __call__(self, mask_pred, threshold=0.5):\n","        debug_info = {'original':  mask_pred.copy(), 'warnings': []}  # ← ĐÃ ĐÚNG\n","        mask_binary = (mask_pred > threshold).astype(np.uint8) * 255\n","        processed = mask_binary.copy()\n","\n","        if self.fill_holes:\n","            processed = self._fill_holes(processed)\n","\n","        if self.remove_small_objects:\n","            if self.smart_mode:  # ← THÊM\n","                processed, warnings_remove = self._remove_small_smart(processed, self.min_object_size)\n","                debug_info['warnings']. extend(warnings_remove)\n","            else:\n","                processed = self._remove_small(processed, self. min_object_size)\n","\n","        if self.smooth_boundary:\n","            processed = self._smooth_boundary(processed)\n","\n","        if self.select_largest:\n","            if self.smart_mode:  # ← THÊM\n","                processed, best_contour, warnings_select = self._select_largest_smart(processed)\n","                debug_info['warnings'].extend(warnings_select)\n","                debug_info['best_contour'] = best_contour\n","            else:\n","                processed, best_contour = self._select_largest(processed)\n","                debug_info['best_contour'] = best_contour\n","\n","        return processed, debug_info\n","\n","    def _fill_holes(self, mask):\n","        kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (11, 11))\n","        closed = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel)\n","        h, w = closed.shape\n","        mask_flood = closed.copy()\n","        cv2.floodFill(mask_flood, None, (0, 0), 255)\n","        mask_flood_inv = cv2.bitwise_not(mask_flood)\n","        return closed | mask_flood_inv\n","\n","    def _remove_small(self, mask, min_size):\n","        num_labels, labels, stats, _ = cv2.connectedComponentsWithStats(mask, connectivity=8)\n","        cleaned = np.zeros_like(mask)\n","        for i in range(1, num_labels):\n","            if stats[i, cv2.CC_STAT_AREA] >= min_size:\n","                cleaned[labels == i] = 255\n","        return cleaned\n","\n","    def _remove_small_smart(self, mask, min_size, min_solidity=0.7):\n","        \"\"\"Smart remove - giữ vùng nhỏ có hình dạng compact\"\"\"\n","        num_labels, labels, stats, _ = cv2.connectedComponentsWithStats(mask, connectivity=8)\n","\n","        mask_cleaned = np.zeros_like(mask)\n","        warnings = []\n","        removed_count = 0\n","        kept_small_count = 0\n","\n","        for i in range(1, num_labels):\n","            area = stats[i, cv2.CC_STAT_AREA]\n","\n","            if area >= min_size:\n","                mask_cleaned[labels == i] = 255\n","                continue\n","\n","            component_mask = (labels == i).astype(np.uint8) * 255\n","            contours, _ = cv2.findContours(component_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","\n","            if len(contours) > 0:\n","                cnt = contours[0]\n","                hull = cv2.convexHull(cnt)\n","                hull_area = cv2.contourArea(hull)\n","\n","                # ← FIX: Tránh chia 0\n","                if hull_area > 0:\n","                    solidity = area / hull_area\n","                    solidity = min(solidity, 1.0)  # Clamp\n","                else:\n","                    solidity = 0.0\n","\n","                if solidity >= min_solidity:\n","                    mask_cleaned[labels == i] = 255\n","                    kept_small_count += 1\n","                    if area > 300:\n","                        warnings.append(f\"Kept small region ({area}px, solidity={solidity:.2f})\")\n","                else:\n","                    removed_count += 1\n","\n","        if removed_count > 0:\n","            warnings.append(f\"Removed {removed_count} small regions\")\n","\n","        if kept_small_count > 0:\n","            warnings.append(f\"⚠️ Kept {kept_small_count} compact regions\")\n","\n","        return mask_cleaned, warnings\n","\n","    def _smooth_boundary(self, mask):\n","        kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (5, 5))\n","        smoothed = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel)\n","        smoothed = cv2.morphologyEx(smoothed, cv2.MORPH_CLOSE, kernel)\n","        return smoothed\n","\n","    def _select_largest(self, mask):\n","        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","        if len(contours) == 0:\n","            return mask, None\n","        contour_features = []\n","        for cnt in contours:\n","            area = cv2.contourArea(cnt)\n","            if area < self.min_object_size:\n","                continue\n","            hull = cv2.convexHull(cnt)\n","            hull_area = cv2.contourArea(hull)\n","            solidity = area / hull_area if hull_area > 0 else 0\n","            score = area * (0.8 + 0.2 * solidity)\n","            contour_features.append({'contour': cnt, 'score': score})\n","        if not contour_features:\n","            return mask, None\n","        best = max(contour_features, key=lambda x: x['score'])\n","        mask_largest = np.zeros_like(mask)\n","        cv2.drawContours(mask_largest, [best['contour']], -1, 255, -1)\n","        return mask_largest, best['contour']\n","\n","    def _select_largest_smart(self, mask):  # ← THÊM\n","        \"\"\"Smart select - phát hiện multiple lesions\"\"\"\n","        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","        warnings = []\n","\n","        if len(contours) == 0:\n","            return mask, None, warnings\n","\n","        if len(contours) == 1:\n","            return mask, contours[0], warnings\n","\n","        contour_data = []\n","        for cnt in contours:\n","            area = cv2.contourArea(cnt)\n","            if area < self.min_object_size:\n","                continue\n","\n","            hull = cv2.convexHull(cnt)\n","            hull_area = cv2.contourArea(hull)\n","            solidity = area / hull_area if hull_area > 0 else 0\n","            score = area * (0.8 + 0.2 * solidity)\n","\n","            M = cv2.moments(cnt)\n","            if M['m00'] != 0:\n","                cx = int(M['m10'] / M['m00'])\n","                cy = int(M['m01'] / M['m00'])\n","            else:\n","                cx, cy = 0, 0\n","\n","            contour_data.append({\n","                'contour': cnt,\n","                'area': area,\n","                'score': score,\n","                'centroid': (cx, cy)\n","            })\n","\n","        if not contour_data:\n","            return mask, None, warnings\n","\n","        contour_data = sorted(contour_data, key=lambda x: x['score'], reverse=True)\n","        top1 = contour_data[0]\n","        top2 = contour_data[1] if len(contour_data) > 1 else None\n","\n","        if top2 is not None:\n","            dist = np.sqrt((top1['centroid'][0] - top2['centroid'][0])**2 +\n","                           (top1['centroid'][1] - top2['centroid'][1])**2)\n","            area_ratio = top2['area'] / top1['area']\n","\n","            if dist > self.distance_threshold and area_ratio > 0.3:\n","                warnings.append(f\"MULTIPLE_LESIONS:  dist={dist:.0f}px, ratio={area_ratio:.2f}\")\n","\n","        mask_largest = np.zeros_like(mask)\n","        cv2.drawContours(mask_largest, [top1['contour']], -1, 255, -1)\n","        return mask_largest, top1['contour'], warnings\n","\n","print(\"✅ PostprocessingPipeline with smart mode defined\")\n","# ------------------------------------------------------------------------------\n","# BƯỚC 3: HELPER FUNCTIONS (Dùng config từ checkpoint)\n","# ------------------------------------------------------------------------------\n","\n","PREPROCESSING_PRESETS = prep_config['preprocessing']['presets']\n","POSTPROCESSING_PRESETS = prep_config['postprocessing']['presets']\n","\n","def get_preprocessing_preset(preset_name):\n","    \"\"\"Tạo PreprocessingPipeline từ preset name\"\"\"\n","    if preset_name not in PREPROCESSING_PRESETS:\n","        raise ValueError(f\"Unknown preset: {preset_name}. Available: {list(PREPROCESSING_PRESETS.  keys())}\")\n","    return PreprocessingPipeline(**PREPROCESSING_PRESETS[preset_name]['config'])\n","\n","def get_postprocessing_preset(preset_name):\n","    \"\"\"Tạo PostprocessingPipeline từ preset name\"\"\"\n","    if preset_name not in POSTPROCESSING_PRESETS:\n","        raise ValueError(f\"Unknown preset: {preset_name}. Available: {list(POSTPROCESSING_PRESETS. keys())}\")\n","    return PostprocessingPipeline(**POSTPROCESSING_PRESETS[preset_name]['config'])\n","\n","print(\"✅ Classes & helpers defined\")\n","print(f\"   - Preprocessing presets: {list(PREPROCESSING_PRESETS. keys())}\")\n","print(f\"   - Postprocessing presets: {list(POSTPROCESSING_PRESETS.keys())}\")\n","\n","print(\"\\n\" + \"=\"*80)"]},{"cell_type":"code","execution_count":22,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":4026,"status":"ok","timestamp":1767519698759,"user":{"displayName":"Hương Giang Nguyễn","userId":"06423650985682136534"},"user_tz":-420},"id":"YD9Vp6yhIkJx","outputId":"28d39122-8fc0-419a-95bd-622607df1c09"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","================================================================================\n","📦 LOADING MODELS\n","================================================================================\n","🖥️ Device: cpu\n","✅ U-Net\n","✅ DeepLabV3+\n","✅ Hybrid\n","✅ Classification (7 classes)\n","✅ USE_CLAHE: False\n"]}],"source":["# ==============================================================================\n","# Ô 3:LOAD MODELS\n","# ==============================================================================\n","\n","print(\"\\n\" + \"=\"*80)\n","print(\"📦 LOADING MODELS\")\n","print(\"=\"*80)\n","\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","import torchvision.transforms as transforms\n","import segmentation_models_pytorch as smp\n","import timm\n","from PIL import Image\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print(f\"🖥️ Device: {device}\")\n","\n","CHECKPOINT_PATH = os.path.join(GDRIVE_PATH, \"3_Checkpoints\")\n","\n","# Load checkpoints\n","with open(os.path.join(CHECKPOINT_PATH, \"02_unet_complete.json\"), 'r') as f:\n","    unet_checkpoint = json.load(f)\n","with open(os.path.join(CHECKPOINT_PATH, \"03_deeplabv3plus_complete.json\"), 'r') as f:\n","    deeplab_checkpoint = json.load(f)\n","with open(os.path.join(CHECKPOINT_PATH, \"06_classification_complete.json\"), 'r') as f:\n","    cls_checkpoint = json.load(f)\n","\n","# U-Net\n","unet_model = smp.Unet(encoder_name=\"resnet34\", encoder_weights=None, in_channels=3, classes=1, activation=None)\n","unet_model.load_state_dict(torch.load(unet_checkpoint['paths']['best_model'], map_location=device)['model_state_dict'])\n","unet_model = unet_model.to(device).eval()\n","print(\"✅ U-Net\")\n","\n","# DeepLabV3+\n","deeplab_model = smp.DeepLabV3Plus(encoder_name=\"resnet50\", encoder_weights=None, in_channels=3, classes=1, activation=None)\n","deeplab_model.load_state_dict(torch.load(deeplab_checkpoint['paths']['best_model'], map_location=device)['model_state_dict'])\n","deeplab_model = deeplab_model. to(device).eval()\n","print(\"✅ DeepLabV3+\")\n","\n","# Hybrid\n","class HybridSegmentation(nn.Module):\n","    def __init__(self, unet, deeplab, method='max'):\n","        super().__init__()\n","        self.unet = unet\n","        self. deeplab = deeplab\n","        self.method = method\n","\n","    def forward(self, x):\n","        with torch.no_grad():\n","            pred_unet = torch.sigmoid(self.unet(x))\n","            pred_deeplab = torch.sigmoid(self.deeplab(x))\n","            return torch.max(pred_unet, pred_deeplab)\n","\n","hybrid_model = HybridSegmentation(unet_model, deeplab_model, method='max').eval()\n","print(\"✅ Hybrid\")\n","\n","# Classification Model\n","class ChannelAttention(nn.Module):\n","    def __init__(self, in_channels, reduction=16):\n","        super().__init__()\n","        self.avg_pool = nn.AdaptiveAvgPool2d(1)\n","        self.max_pool = nn.AdaptiveMaxPool2d(1)\n","        self.fc = nn.Sequential(\n","            nn.Conv2d(in_channels, in_channels // reduction, 1, bias=False),\n","            nn.ReLU(inplace=True),\n","            nn.Conv2d(in_channels // reduction, in_channels, 1, bias=False)\n","        )\n","        self.sigmoid = nn.Sigmoid()\n","\n","    def forward(self, x):\n","        return self.sigmoid(self.fc(self.avg_pool(x)) + self.fc(self.max_pool(x)))\n","\n","class SpatialAttention(nn.Module):\n","    def __init__(self, kernel_size=7):\n","        super().__init__()\n","        self.conv = nn.Conv2d(2, 1, kernel_size, padding=kernel_size//2, bias=False)\n","        self.sigmoid = nn.Sigmoid()\n","\n","    def forward(self, x):\n","        avg_out = torch.mean(x, dim=1, keepdim=True)\n","        max_out, _ = torch.max(x, dim=1, keepdim=True)\n","        return self.sigmoid(self.conv(torch.cat([avg_out, max_out], dim=1)))\n","\n","class CBAM(nn.Module):\n","    def __init__(self, in_channels, reduction=16):\n","        super().__init__()\n","        self.channel_att = ChannelAttention(in_channels, reduction)\n","        self.spatial_att = SpatialAttention()\n","\n","    def forward(self, x):\n","        return x * self.channel_att(x) * self.spatial_att(x * self.channel_att(x))\n","\n","class EfficientNetWithAttention(nn.Module):\n","    def __init__(self, num_classes, pretrained=False):\n","        super().__init__()\n","        self.backbone = timm.create_model('efficientnet_b0', pretrained=pretrained, num_classes=0)\n","        self.feature_dim = self.backbone.num_features\n","        self.attention = CBAM(self.feature_dim, reduction=16)\n","        self.global_pool = nn.AdaptiveAvgPool2d(1)\n","        self.classifier = nn.Sequential(\n","            nn.Dropout(0.3),\n","            nn.Linear(self.feature_dim, 512),\n","            nn.ReLU(inplace=True),\n","            nn.Dropout(0.3),\n","            nn.Linear(512, num_classes)\n","        )\n","\n","    def forward(self, x):\n","        features = self.backbone.forward_features(x)\n","        features_att = self.attention(features)\n","        features_pooled = self.global_pool(features_att).flatten(1)\n","        return self.classifier(features_pooled)\n","\n","# Load classification model\n","cls_state = torch.load(cls_checkpoint['paths']['best_model'], map_location=device)\n","num_classes = cls_checkpoint['config']['num_classes']\n","class_to_idx = cls_state['class_to_idx']\n","idx_to_class = {v: k for k, v in class_to_idx.items()}\n","\n","cls_model = EfficientNetWithAttention(num_classes=num_classes, pretrained=False)\n","cls_model.load_state_dict(cls_state['model_state_dict'])\n","cls_model = cls_model.to(device).eval()\n","print(f\"✅ Classification ({num_classes} classes)\")\n","\n","# USE_CLAHE\n","preprocessing_config = cls_checkpoint. get('preprocessing', {})\n","USE_CLAHE = preprocessing_config.get('use_clahe', False)\n","print(f\"✅ USE_CLAHE: {USE_CLAHE}\")"]},{"cell_type":"code","execution_count":23,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":841,"status":"ok","timestamp":1767519699603,"user":{"displayName":"Hương Giang Nguyễn","userId":"06423650985682136534"},"user_tz":-420},"id":"2kswIuexI9bF","outputId":"c917fde1-3923-4926-b0b3-a938c041894b"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ detect_overlapping_lesions defined\n","✅ Option A:  Prioritize Mask in Tier 4\n","✅ Adaptive predict_single_image defined\n","✅ Fixed save_visualization (removed uncertainty)\n"]}],"source":["# ==============================================================================\n","# Ô 4: HELPER FUNCTIONS\n","# ==============================================================================\n","# ← PASTE CÁC HÀM SAU TỪ FILE 08:\n","from datetime import datetime # CORRECTED THIS LINE\n","def preprocess_for_segmentation(image):\n","    img = cv2.resize(image, (256, 256)).astype(np.float32) / 255.0\n","    mean = np.array([0.485, 0.456, 0.406])\n","    std = np.array([0.229, 0.224, 0.225])\n","    img = (img - mean) / std\n","    return torch.from_numpy(img).permute(2, 0, 1).unsqueeze(0).float()\n","\n","def fallback_center_crop(image, target_size=(224, 224)):\n","    h, w = image.shape[:2]\n","    side = min(h, w)\n","    cx, cy = w // 2, h // 2\n","    half = side // 2\n","    x1 = max(0, cx - half)\n","    y1 = max(0, cy - half)\n","    x2 = min(w, cx + half)\n","    y2 = min(h, cy + half)\n","    roi = image[y1:y2, x1:x2]\n","    roi_resized = cv2.resize(roi, target_size, interpolation=cv2.INTER_LANCZOS4)\n","    return roi_resized, (x1, y1, x2, y2)\n","\n","def extract_roi_improved(image, mask, min_padding_ratio=0.15, target_size=(224, 224)):\n","    \"\"\"\n","    ROI extraction an toàn: fallback center-crop khi mask quá to/nhỏ hoặc không có contour.\n","    mask: (H, W) trong [0,1]\n","    \"\"\"\n","    h, w = image.shape[:2]\n","    mask = np.clip(mask, 0, 1)\n","    mask_binary = (mask > 0.5).astype(np.uint8)\n","\n","    # Coverage check\n","    coverage = mask_binary.sum() / float(h * w)\n","    if coverage > 0.8 or coverage < 0.01:\n","        print(f\"⚠️ Mask coverage {coverage:.3f} out of range → center crop\")\n","        roi_resized, bbox = fallback_center_crop(image, target_size)\n","        return roi_resized, bbox, 0.0\n","\n","    # Find contours\n","    contours, _ = cv2.findContours(mask_binary, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","    if len(contours) == 0:\n","        print(\"⚠️ No contour → center crop\")\n","        roi_resized, bbox = fallback_center_crop(image, target_size)\n","        return roi_resized, bbox, 0.0\n","\n","    largest_contour = max(contours, key=cv2.contourArea)\n","    x, y, bw, bh = cv2.boundingRect(largest_contour)\n","\n","    # Adaptive padding\n","    bbox_size = max(bw, bh)\n","    padding = max(int(bbox_size * min_padding_ratio), 20)\n","    x1 = max(0, x - padding)\n","    y1 = max(0, y - padding)\n","    x2 = min(w, x + bw + padding)\n","    y2 = min(h, y + bh + padding)\n","\n","    # Nếu bbox quá lớn (>70% ảnh) → center crop\n","    bbox_area = (x2 - x1) * (y2 - y1)\n","    if bbox_area / float(w * h) > 0.7:\n","        print(f\"⚠️ BBox too large ({bbox_area/(w*h):.2f}) → center crop\")\n","        roi_resized, bbox = fallback_center_crop(image, target_size)\n","        return roi_resized, bbox, 0.0\n","\n","    # Crop ROI\n","    roi = image[y1:y2, x1:x2]\n","    if roi.size == 0:\n","        print(\"⚠️ Empty ROI → center crop\")\n","        roi_resized, bbox = fallback_center_crop(image, target_size)\n","        return roi_resized, bbox, 0.0\n","\n","    # ROI quá nhỏ → center crop\n","    if roi.shape[0] < 50 or roi.shape[1] < 50:\n","        print(f\"⚠️ ROI too small ({roi.shape[0]}x{roi.shape[1]}) → center crop\")\n","        roi_resized, bbox = fallback_center_crop(image, target_size)\n","        return roi_resized, bbox, 0.0\n","\n","    # Resize to target\n","    roi_resized = cv2.resize(roi, target_size, interpolation=cv2.INTER_LANCZOS4)\n","\n","    # Tính quality_score đơn giản: coverage & mean conf trên mask (như trước)\n","    mask_area = mask_binary.sum()\n","    mask_mean_confidence = mask[mask_binary > 0].mean() if mask_area > 0 else 0\n","    quality_score = 0.5 * coverage + 0.5 * mask_mean_confidence\n","\n","    print(f\"   ✅ ROI: {roi.shape} → {target_size}, bbox: ({x1},{y1},{x2},{y2})\")\n","    return roi_resized, (x1, y1, x2, y2), quality_score\n","\n","def preprocess_for_classification_v2(roi, apply_clahe=True):\n","    \"\"\"\n","    Preprocessing giống như training pipeline\n","\n","    Args:\n","        roi: RGB numpy array (224, 224, 3) - đã resize\n","        apply_clahe: Có áp dụng CLAHE để chuẩn hóa contrast\n","\n","    Returns:\n","        tensor: (1, 3, 224, 224)\n","    \"\"\"\n","    # OPTIONAL: Apply CLAHE để normalize contrast (giống ảnh HAM10000)\n","    if apply_clahe:\n","        lab = cv2.cvtColor(roi, cv2.COLOR_RGB2LAB)\n","        clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))\n","        lab[:, :, 0] = clahe.apply(lab[:, :, 0])\n","        roi = cv2.cvtColor(lab, cv2.COLOR_LAB2RGB)\n","\n","    # Convert to PIL\n","    img = Image.fromarray(roi)\n","\n","    # Transform giống validation set\n","    transform = transforms.Compose([\n","        transforms.Resize((224, 224)),  # Đảm bảo size chính xác\n","        transforms.ToTensor(),\n","        transforms.Normalize(mean=[0.485, 0.456, 0.406],\n","                           std=[0.229, 0.224, 0.225])\n","    ])\n","\n","    return transform(img).unsqueeze(0)\n","def ensemble_predict_skin_lesion(model, image_tensor, device, use_tta=True, confidence_threshold=0.7):\n","    \"\"\"\n","    TTA phù hợp cho da liễu: chỉ flip, KHÔNG rotate\n","\n","    Args:\n","        model: Classification model\n","        image_tensor: (1, 3, 224, 224)\n","        device: cuda/cpu\n","        use_tta: Enable TTA\n","        confidence_threshold: Ngưỡng cảnh báo low confidence\n","\n","    Returns:\n","        dict: pred_idx, confidence, uncertainty, probs, warning\n","    \"\"\"\n","    model.eval()\n","\n","    with torch.no_grad():\n","        if not use_tta:\n","            output = model(image_tensor.to(device))\n","            probs = F.softmax(output, dim=1).cpu().numpy()[0]\n","            pred_idx = np.argmax(probs)\n","            return {\n","                'pred_idx': pred_idx,\n","                'confidence': probs[pred_idx],\n","                'uncertainty': 0.0,\n","                'probs': probs,\n","                'warning': probs[pred_idx] < confidence_threshold\n","            }\n","\n","        all_probs = []\n","\n","        # 1. Original\n","        output = model(image_tensor.to(device))\n","        all_probs.append(F.softmax(output, dim=1))\n","\n","        # 2. Horizontal flip (da liễu có thể trái/phải)\n","        flipped_h = torch.flip(image_tensor, dims=[3])\n","        output_h = model(flipped_h.to(device))\n","        all_probs.append(F.softmax(output_h, dim=1))\n","\n","        # 3. Vertical flip (ít phổ biến hơn)\n","        flipped_v = torch.flip(image_tensor, dims=[2])\n","        output_v = model(flipped_v.to(device))\n","        all_probs.append(F.softmax(output_v, dim=1))\n","\n","        # 4. Both flips\n","        flipped_both = torch.flip(image_tensor, dims=[2, 3])\n","        output_both = model(flipped_both.to(device))\n","        all_probs.append(F.softmax(output_both, dim=1))\n","\n","        # ❌ KHÔNG dùng rotate 90/270 cho skin lesion\n","\n","        # Average probabilities\n","        avg_probs = torch.mean(torch.stack(all_probs), dim=0).cpu().numpy()[0]\n","        pred_idx = np.argmax(avg_probs)\n","        confidence = avg_probs[pred_idx]\n","\n","        # Calculate uncertainty\n","        all_preds = [torch.argmax(p, dim=1).item() for p in all_probs]\n","        uncertainty = 1.0 - (all_preds.count(pred_idx) / len(all_preds))\n","        if uncertainty > 0.3:  # Agreement thấp, cảnh báo\n","            adjusted_confidence = confidence * (1.0 - uncertainty)\n","            print(f\"⚠️ TTA agreement low: reducing confidence ({confidence:.2f} → {adjusted_confidence:.2f})\")\n","            confidence = adjusted_confidence  # Cập nhật confidence\n","        # Warning nếu TTA predictions không đồng nhất\n","        warning = (confidence < confidence_threshold) or (uncertainty > 0.3)\n","\n","        return {\n","            'pred_idx': pred_idx,\n","            'confidence': confidence,\n","            'uncertainty': uncertainty,\n","            'probs': avg_probs,\n","            'warning': warning,\n","            'tta_agreement': f\"{all_preds.count(pred_idx)}/{len(all_probs)}\"\n","        }\n","\n","# ==============================================================================\n","# OVERLAPPING DETECTION\n","# ==============================================================================\n","\n","def detect_overlapping_lesions(mask):\n","    \"\"\"\n","    Phát hiện tổn thương chồng lấn dựa trên solidity thấp hoặc nhiều vùng\n","\n","    Args:\n","        mask: Binary mask uint8 [0, 255]\n","\n","    Returns:\n","        is_overlapping: bool\n","        warnings: list of str\n","        solidity:  float\n","    \"\"\"\n","    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n","\n","    if len(contours) == 0:\n","        return False, [], 1.0\n","\n","    warnings = []\n","    is_overlapping = False\n","\n","    # Trường hợp nhiều contour (>1)\n","    if len(contours) > 1:\n","        warnings.append(f\"Multiple regions detected ({len(contours)} regions)\")\n","        for i, cnt in enumerate(contours):\n","            area = cv2.contourArea(cnt)\n","            if area > 0:\n","                warnings.append(f\"Region {i + 1}: Area = {area:.1f}px\")\n","        is_overlapping = True  # Cảnh báo vùng chồng lấn\n","\n","    # Kiểm tra tính compact của vùng lớn nhất\n","    cnt = max(contours, key=cv2.contourArea)\n","    area = cv2.contourArea(cnt)\n","\n","    if area < 200:  # Quá nhỏ, bỏ qua\n","        warnings.append(\"Region area too small (<200px)\")\n","        return False, warnings, 1.0\n","\n","    hull = cv2.convexHull(cnt)\n","    hull_area = cv2.contourArea(hull)\n","    solidity = area / hull_area if hull_area > 0 else 1.0\n","\n","    # Solidity < 0.75 → Hình dạng không compact (cảnh báo)\n","    if solidity < 0.75:\n","        is_overlapping = True\n","        warnings.append(f\"Overlapping detected (solidity={solidity:.2f})\")\n","        warnings.append(\"Non-compact shape - possible multiple overlapping lesions\")\n","        warnings.append(\"Recommendation: Re-capture with closer zoom, separate lesions if possible\")\n","\n","    return is_overlapping, warnings, solidity\n","\n","\n","print(\"✅ detect_overlapping_lesions defined\")\n","# ==============================================================================\n","# THÊM ĐOẠN NÀY SAU HÀM ensemble_predict_skin_lesion\n","# ==============================================================================\n","\n","\n","\n","\n","def select_preprocessing_strategy(image_quality, image_issues, mask_quality, classification_confidence):\n","    \"\"\"\n","    Chiến lược của bạn + Cải tiến điểm 4 (Ưu tiên Mask)\n","\n","    1. Confidence CAO → Tin model\n","    2. Confidence THẤP + Image XẤU → Full preprocessing\n","    3. Confidence THẤP + Image OK → Light preprocessing\n","    4. Confidence TRUNG BÌNH → Ưu tiên Mask, sau đó Image\n","    \"\"\"\n","    # Thresholds\n","    HIGH_CONFIDENCE = 0.85\n","    LOW_CONFIDENCE = 0.70\n","    MIN_MASK_QUALITY = 0.50\n","    POOR_MASK = 0.40\n","    VERY_POOR_IMAGE = 0.30\n","\n","    # ========== TIER 1: CONFIDENCE CAO → TIN MODEL ==========\n","    if classification_confidence >= HIGH_CONFIDENCE and mask_quality >= MIN_MASK_QUALITY:\n","        return 'none', f\"High confidence ({classification_confidence:.2f}) - trust model\"\n","\n","    # ========== TIER 2 & 3: CONFIDENCE THẤP ==========\n","    if classification_confidence < LOW_CONFIDENCE:\n","        # 2. Confidence THẤP + Image XẤU → Full\n","        if image_quality < VERY_POOR_IMAGE:\n","            return 'full', f\"Low conf ({classification_confidence:.2f}) + very poor image ({image_quality:.2f})\"\n","        # 3. Confidence THẤP + Image OK → Light\n","        else:\n","            return 'light', f\"Low conf ({classification_confidence:.2f}) + acceptable image ({image_quality:.2f})\"\n","\n","    # ========== TIER 4: CONFIDENCE TRUNG BÌNH (70-85%) ==========\n","    # 4a. Mask KÉM → Light preprocessing (ưu tiên sửa segmentation)\n","    if mask_quality < POOR_MASK:\n","        return 'light', f\"Medium conf ({classification_confidence:.2f}) + poor mask ({mask_quality:.2f})\"\n","    # if mask_quality < POOR_MASK and roi_quality >= 0.7:\n","    #     return 'light', f\"High ROI quality ({roi_quality:.2f}) but poor mask ({mask_quality:.2f})\"\n","    # 4b. Mask OK → Xem image quality\n","    if image_quality < VERY_POOR_IMAGE:\n","        return 'light', f\"Medium conf ({classification_confidence:.2f}) + poor image ({image_quality:.2f})\"\n","    else:\n","        return 'none', f\"Medium conf ({classification_confidence:.2f}) + acceptable quality\"\n","\n","\n","print(\"✅ Option A:  Prioritize Mask in Tier 4\")\n","def _assess_overall_quality(image_quality, mask_quality, roi_quality):\n","    \"\"\"\n","    Đánh giá chất lượng tổng thể\n","\n","    Returns:\n","        str: 'TỐT', 'TRUNG BÌNH', 'KÉM'\n","    \"\"\"\n","    avg_quality = (image_quality + mask_quality + roi_quality) / 3\n","\n","    if avg_quality >= 0.6 and mask_quality >= 0.6:\n","        return 'TỐT'\n","    elif avg_quality >= 0.4 or mask_quality >= 0.5:\n","        return 'TRUNG BÌNH'\n","    else:\n","        return 'KÉM'\n","\n","\n","def _generate_recommendation(warnings, image_quality, mask_quality, confidence):\n","    \"\"\"\n","    Tạo khuyến nghị dựa trên chất lượng\n","\n","    Returns:\n","        str:  Khuyến nghị cho người dùng\n","    \"\"\"\n","    recommendations = []\n","\n","    # 1. Confidence thấp\n","    if confidence < 0.70:\n","        recommendations.append(\"Độ tin cậy dự đoán thấp.  Khuyến nghị xem xét lại bởi chuyên gia.\")\n","\n","    # 2. Image quality kém\n","    if image_quality < 0.3:\n","        recommendations.append(\"Chất lượng ảnh đầu vào kém. Nên chụp lại ảnh với ánh sáng tốt hơn.\")\n","\n","    # 3. Mask quality kém\n","    if mask_quality < 0.4:\n","        recommendations. append(\"Phân đoạn tổn thương không rõ ràng. Có thể cần chụp lại hoặc xem xét thủ công.\")\n","\n","    # 4. Có warnings cụ thể\n","    if 'hair' in str(warnings).lower():\n","        recommendations.append(\"Phát hiện lông che phủ. Đã áp dụng xử lý tự động, nhưng nên xem xét thêm.\")\n","\n","    if 'shadow' in str(warnings).lower():\n","        recommendations.append(\"Phát hiện bóng tối.  Đã cố gắng điều chỉnh, nhưng kết quả có thể bị ảnh hưởng.\")\n","\n","    # 5. Không có vấn đề\n","    if not recommendations:\n","        if confidence >= 0.85 and mask_quality >= 0.6:\n","            recommendations.append(\"Chất lượng tốt.  Kết quả đáng tin cậy.\")\n","        else:\n","            recommendations.append(\"Chất lượng chấp nhận được. Nên xem xét thêm nếu có triệu chứng lâm sàng.\")\n","\n","    return \" \".join(recommendations)\n","# ==============================================================================\n","# THAY HÀM NÀY (Ô CODE 4)\n","# ==============================================================================\n","# def fallback_center_crop(image, target_size=(224, 224)):\n","#     \"\"\"Center-crop theo chiều ngắn nhất rồi resize.\"\"\"\n","#     h, w = image.shape[:2]\n","#     side = min(h, w)\n","#     cx, cy = w // 2, h // 2\n","#     half = side // 2\n","#     x1 = max(0, cx - half)\n","#     y1 = max(0, cy - half)\n","#     x2 = min(w, cx + half)\n","#     y2 = min(h, cy + half)\n","#     roi = image[y1:y2, x1:x2]\n","#     roi_resized = cv2.resize(roi, target_size, interpolation=cv2.INTER_LANCZOS4)\n","#     return roi_resized, (x1, y1, x2, y2)\n","\n","# def estimate_mask_quality(mask_pred):\n","#     mask = np.clip(mask_pred, 0, 1).astype(np.float32)\n","#     mask_area = (mask > 0.5).sum()\n","#     total_area = mask.size\n","#     coverage = mask_area / total_area\n","#     # Penalize cực trị mạnh hơn\n","#     if coverage > 0.8 or coverage < 0.01:\n","#         coverage_score = 0.1\n","#     elif coverage > 0.6 or coverage < 0.02:\n","#         coverage_score = 0.3\n","#     else:\n","#         coverage_score = 1.0\n","#     confidence_map = np.abs(mask - 0.5)\n","#     avg_confidence = confidence_map.mean() * 2\n","#     quality_score = coverage_score * 0.4 + avg_confidence * 0.6\n","#     quality_info = {\n","#         'coverage': float(coverage),\n","#         'confidence': float(avg_confidence),\n","#         'overall': float(quality_score)\n","#     }\n","#     return quality_score, quality_info\n","\n","# def extract_roi_improved(image, mask, min_padding_ratio=0.15, target_size=(224, 224)):\n","#     h, w = image.shape[:2]\n","#     mask_binary = (mask > 0.5).astype(np.uint8)\n","#     mask_area = mask_binary.sum()\n","#     coverage = mask_area / (h * w)\n","#     if coverage > 0.7 or coverage < 0.01:\n","#         print(f\"⚠️ Mask coverage {coverage:.3f} out of range → center crop\")\n","#         roi_resized, bbox = fallback_center_crop(image, target_size)\n","#         return roi_resized, bbox, 0.0\n","\n","#     # ... giữ nguyên logic cũ từ tìm contour, padding ...\n","#     # (sau khi tính bbox)\n","#     bbox_area = (x2 - x1) * (y2 - y1)\n","#     if bbox_area / (w * h) > 0.7:\n","#         print(f\"⚠️ BBox too large ({bbox_area/(w*h):.2f}) → center crop\")\n","#         roi_resized, bbox = fallback_center_crop(image, target_size)\n","#         return roi_resized, bbox, 0.0\n","\n","def remove_small_regions(mask, min_size=500):\n","    \"\"\"\n","    Loại bỏ các vùng nhỏ trong mask dựa trên diện tích (min_size).\n","    Args:\n","        mask (np.array): Mask dạng binary (0 và 255).\n","        min_size (int): Ngưỡng diện tích tối thiểu cho vùng.\n","    Returns:\n","        np.array: Mask đã được làm sạch vùng nhỏ.\n","    \"\"\"\n","    # Xác định các vùng kết nối\n","    num_labels, labels, stats, _ = cv2.connectedComponentsWithStats(mask, connectivity=8)\n","    cleaned_mask = np.zeros_like(mask)  # Khởi tạo mask sạch\n","    for i in range(1, num_labels):  # Bỏ qua label 0 (background)\n","        if stats[i, cv2.CC_STAT_AREA] >= min_size:  # Giữ vùng lớn hơn ngưỡng\n","            cleaned_mask[labels == i] = 255\n","    return cleaned_mask\n","\n","def predict_single_image_adaptive(image_path,\n","                                 save_results=True,\n","                                 debug=False,\n","                                 use_clahe=True):\n","    \"\"\"\n","    ADAPTIVE PIPELINE:\n","    1. Inference baseline (không preprocessing)\n","    2. Đánh giá:  image quality + mask quality + confidence\n","    3. NẾU kém → Preprocessing + inference lại\n","    4. So sánh → Chọn tốt hơn\n","\n","    Args:\n","        image_path:  Đường dẫn ảnh\n","        save_results:  Lưu kết quả\n","        debug: Hiển thị visualization\n","        use_clahe:  Dùng CLAHE cho classification\n","\n","    Returns:\n","        results: Dictionary kết quả\n","    \"\"\"\n","    # Load image\n","    image = cv2.imread(image_path)\n","    if image is None:\n","        raise ValueError(f\"Cannot load:  {image_path}\")\n","\n","    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n","    original_size = image_rgb.shape[:2]\n","\n","    print(f\"\\n{'='*80}\")\n","    print(f\"📸 ADAPTIVE INFERENCE:  {os.path.basename(image_path)}\")\n","    print(f\"   Size: {original_size[1]}x{original_size[0]}\")\n","    print(f\"{'='*80}\")\n","\n","\n","    # ========== BƯỚC 1: ĐÁNH GIÁ CHẤT LƯỢNG ẢNH ==========\n","    print(\"\\n🔍 STEP 1: Image Quality Assessment\")\n","    image_quality, image_details, image_issues = estimate_image_quality(image_rgb)\n","    print(f\"   Image Quality: {image_quality:.3f}\")\n","    if image_issues:\n","        print(f\"   Issues detected: {', '.join(image_issues)}\")\n","\n","    # ========== BƯỚC 2: BASELINE INFERENCE ==========\n","    print(\"\\n🔬 STEP 2: Baseline Inference (No Preprocessing)\")\n","\n","    # Segmentation\n","    img_tensor_baseline = preprocess_for_segmentation(image_rgb).to(device)\n","\n","    with torch.no_grad():\n","        mask_pred_baseline = hybrid_model(img_tensor_baseline).squeeze().cpu().numpy()\n","\n","    # Hậu xử lý mask: Loại bỏ vùng nhỏ (min_size=500)\n","    # Baseline\n","    mask_binary_baseline = (mask_pred_baseline > 0.5).astype(np.uint8) * 255\n","    mask_cleaned_baseline = remove_small_regions(mask_binary_baseline, min_size=500)\n","    mask_resized_baseline = cv2.resize(mask_cleaned_baseline, (original_size[1], original_size[0]))\n","    mask_resized_baseline_01 = mask_resized_baseline.astype(np.float32) / 255.0\n","\n","    # Ước lượng chất lượng mask sau khi làm sạch\n","    mask_quality_baseline, mask_details_baseline = estimate_mask_quality(mask_resized_baseline_01)\n","    print(f\"   Mask Quality: {mask_quality_baseline:.3f}\")\n","    # coverage_baseline = mask_details_baseline['coverage']\n","    # use_fallback_baseline = (coverage_baseline > 0.6) or (coverage_baseline < 0.02)\n","\n","    # if use_fallback_baseline:\n","    #     print(f\"⚠️ Mask coverage {coverage_baseline:.3f} → fallback center crop\")\n","    #     roi_baseline, bbox_baseline = fallback_center_crop(image_rgb, target_size=(224, 224))\n","    #     roi_quality_baseline = 0.0\n","    #     mask_quality_baseline = 0.0\n","    # else:\n","    #     roi_baseline, bbox_baseline, roi_quality_baseline = extract_roi_improved(\n","    #         image_rgb, mask_resized_baseline_01\n","    #     )\n","    # ROI extraction\n","    roi_baseline, bbox_baseline, roi_quality_baseline = extract_roi_improved(image_rgb, mask_resized_baseline_01)\n","\n","    # Classification\n","    roi_tensor_baseline = preprocess_for_classification_v2(roi_baseline, apply_clahe=use_clahe)\n","    ensemble_result_baseline = ensemble_predict_skin_lesion(cls_model, roi_tensor_baseline, device, use_tta=True)\n","\n","    confidence_baseline = ensemble_result_baseline['confidence']\n","    prediction_baseline = idx_to_class[ensemble_result_baseline['pred_idx']]\n","\n","    print(f\"   Prediction: {prediction_baseline}\")\n","    print(f\"   Confidence:  {confidence_baseline*100:.1f}%\")\n","\n","    # ========== BƯỚC 3: QUYẾT ĐỊNH CÓ CẦN PREPROCESSING?  ==========\n","    print(f\"\\n🤔 STEP 3: Decision Making\")\n","\n","    decision, reason = select_preprocessing_strategy(\n","        image_quality, image_issues, mask_quality_baseline, confidence_baseline\n","    )\n","\n","    print(f\"   Decision: {decision. upper()}\")\n","    print(f\"   Reason: {reason}\")\n","\n","    # ========== BƯỚC 4: XỬ LÝ THEO QUYẾT ĐỊNH ==========\n","    if decision == 'none':\n","        # ✅ Dùng baseline\n","        print(f\"\\n✅ Using BASELINE results (no preprocessing needed)\")\n","\n","        final_prediction = prediction_baseline\n","        final_confidence = confidence_baseline\n","        final_probs = ensemble_result_baseline['probs']\n","        final_roi = roi_baseline\n","        final_mask = mask_resized_baseline\n","        final_bbox = bbox_baseline\n","        preprocessing_used = 'none'\n","        improvement = 0.0\n","        # ← THÊM: Overlapping detection\n","        overlapping_detected, overlapping_warnings, solidity_score = detect_overlapping_lesions(\n","            mask_resized_baseline\n","        )\n","        post_warnings_final = []\n","\n","    else:\n","        # ⚠️ Áp dụng preprocessing\n","        print(f\"\\n⚠️ STEP 4: Applying Preprocessing & Re-inference\")\n","\n","        # Chọn preset\n","        if decision == 'full':\n","            preset_pre = 'smartphone_light'\n","            preset_post = 'noisy'\n","        else:  # light\n","            preset_pre = 'clinic'\n","            preset_post = 'noisy'\n","\n","        print(f\"   Preprocessing:  {preset_pre}\")\n","        print(f\"   Postprocessing: {preset_post}\")\n","\n","        preprocess = get_preprocessing_preset(preset_pre)\n","        postprocess = get_postprocessing_preset(preset_post)\n","\n","        # Preprocessing\n","        image_enhanced, _ = preprocess(image_rgb)\n","\n","        # Segmentation\n","        img_tensor_enhanced = preprocess_for_segmentation(image_enhanced).to(device)\n","\n","        with torch.no_grad():\n","            mask_pred_enhanced = hybrid_model(img_tensor_enhanced).squeeze().cpu().numpy()\n","\n","        # Làm sạch mask sau segmentation\n","        mask_binary_enhanced = (mask_pred_enhanced > 0.5).astype(np.uint8) * 255\n","        mask_cleaned_enhanced = remove_small_regions(mask_binary_enhanced, min_size=500)\n","        mask_resized_enhanced = cv2.resize(mask_cleaned_enhanced, (original_size[1], original_size[0]))\n","\n","        # Hậu xử lý mask đã làm sạch\n","        mask_final_binary, post_debug = postprocess(mask_resized_enhanced, threshold=0.5)\n","        mask_final_01 = mask_final_binary.astype(np.float32) / 255.0\n","        mask_quality_enh, mask_details_enh = estimate_mask_quality(mask_final_01)\n","        # coverage_enh = mask_details_enh['coverage']\n","        # use_fallback_enh = (coverage_enh > 0.6) or (coverage_enh < 0.02)\n","\n","        # if use_fallback_enh:\n","        #     print(f\"⚠️ Mask coverage {coverage_enh:.3f} → fallback center crop (enhanced)\")\n","        #     roi_enhanced, bbox_enhanced = fallback_center_crop(image_enhanced, target_size=(224, 224))\n","        #     roi_quality_enhanced = 0.0\n","        #     mask_quality_enh = 0.0\n","        # else:\n","        #     roi_enhanced, bbox_enhanced, roi_quality_enhanced = extract_roi_improved(\n","        #         image_enhanced, mask_final_01\n","        #     )\n","\n","        # ← THÊM: Collect postprocessing warnings\n","        post_warnings = post_debug. get('warnings', [])\n","\n","        # ← THÊM: Overlapping detection\n","        overlapping_detected_enh, overlapping_warnings_enh, solidity_enh = detect_overlapping_lesions(mask_final_binary)\n","\n","        # ROI extraction\n","        roi_enhanced, bbox_enhanced, roi_quality_enhanced = extract_roi_improved(image_enhanced, mask_final_01)\n","\n","        # Classification\n","        roi_tensor_enhanced = preprocess_for_classification_v2(roi_enhanced, apply_clahe=use_clahe)\n","        ensemble_result_enhanced = ensemble_predict_skin_lesion(cls_model, roi_tensor_enhanced, device, use_tta=True)\n","\n","        confidence_enhanced = ensemble_result_enhanced['confidence']\n","        prediction_enhanced = idx_to_class[ensemble_result_enhanced['pred_idx']]\n","\n","        print(f\"   Enhanced Prediction: {prediction_enhanced}\")\n","        print(f\"   Enhanced Confidence: {confidence_enhanced*100:.1f}%\")\n","\n","        # ========== SO SÁNH ==========\n","        improvement = confidence_enhanced - confidence_baseline\n","        print(f\"\\n📊 Comparison:\")\n","        print(f\"   Baseline:   {prediction_baseline} ({confidence_baseline*100:.1f}%)\")\n","        print(f\"   Enhanced:   {prediction_enhanced} ({confidence_enhanced*100:.1f}%)\")\n","        print(f\"   Improvement: {improvement*100:+.1f}%\")\n","\n","        # Chọn kết quả tốt hơn\n","        if confidence_enhanced > confidence_baseline:\n","            print(f\"\\n✅ Using ENHANCED result (better confidence)\")\n","            final_prediction = prediction_enhanced\n","            final_confidence = confidence_enhanced\n","            final_probs = ensemble_result_enhanced['probs']\n","            final_roi = roi_enhanced\n","            final_mask = mask_final_01\n","            final_bbox = bbox_enhanced\n","            preprocessing_used = preset_pre\n","            # ← THÊM:  Overlapping info\n","            overlapping_detected = overlapping_detected_enh\n","            overlapping_warnings = overlapping_warnings_enh\n","            solidity_score = solidity_enh\n","            post_warnings_final = post_warnings\n","\n","        else:\n","            print(f\"\\n⚠️ Enhancement did NOT improve → Using BASELINE\")\n","            final_prediction = prediction_baseline\n","            final_confidence = confidence_baseline\n","            final_probs = ensemble_result_baseline['probs']\n","            final_roi = roi_baseline\n","            final_mask = mask_resized_baseline\n","            final_bbox = bbox_baseline\n","            preprocessing_used = 'none'\n","            # ← THÊM: Overlapping detection cho baseline\n","            overlapping_detected, overlapping_warnings, solidity_score = detect_overlapping_lesions(\n","                (mask_resized_baseline * 255).astype(np.uint8)\n","            )\n","            post_warnings_final = []\n","\n","    # ========== KẾT QUẢ CUỐI CÙNG ==========\n","    entropy = -np.sum(final_probs * np.log(final_probs + 1e-10))\n","\n","    print(f\"\\n{'='*80}\")\n","    print(f\"📊 FINAL RESULTS\")\n","    print(f\"{'='*80}\")\n","    print(f\"   Prediction: {final_prediction}\")\n","    print(f\"   Confidence:  {final_confidence*100:.2f}%\")\n","    print(f\"   Preprocessing:  {preprocessing_used}\")\n","    if decision != 'none':\n","        print(f\"   Improvement: {improvement*100:+.1f}%\")\n","\n","    # Warnings\n","    warnings = []\n","    confidence_original = final_confidence  # THÊM: Lưu confidence gốc\n","    if final_confidence < 0.7:\n","        warnings.append(\"Low confidence\")\n","    if image_quality < 0.5:\n","        warnings.append(\"Low image quality\")\n","\n","    # ← THÊM: Postprocessing warnings\n","    if 'post_warnings_final' in locals() and post_warnings_final:\n","        for w in post_warnings_final:\n","            if 'MULTIPLE_LESIONS' in w:\n","                warnings.append(\"Multiple lesions detected\")\n","\n","    # ← THÊM: Overlapping warnings + confidence adjustment\n","    if overlapping_detected:\n","        warnings.append(f\"Overlapping lesions (solidity={solidity_score:.2f})\")\n","\n","        # ← ĐIỀU CHỈNH CONFIDENCE\n","        final_confidence = final_confidence * 0.8  # Giảm 20%\n","        warnings.append(f\"Confidence adjusted:  {confidence_original*100:.1f}% → {final_confidence*100:.1f}%\")\n","\n","    if warnings:\n","        print(f\"\\n⚠️ Warnings: {', '.join(warnings)}\")\n","\n","    # Debug visualization\n","    if debug:\n","        fig, axes = plt.subplots(2, 3, figsize=(18, 12))\n","\n","        # Row 1\n","        axes[0, 0].imshow(image_rgb)\n","        axes[0, 0].set_title('Original Image')\n","        axes[0, 0].axis('off')\n","\n","        axes[0, 1].imshow(final_mask, cmap='hot')\n","        axes[0, 1].set_title(f'Mask\\nQuality: {mask_quality_baseline:.3f}')\n","        axes[0, 1].axis('off')\n","\n","        overlay = image_rgb.copy()\n","        mask_colored = cv2.applyColorMap(np.uint8(255*final_mask), cv2.COLORMAP_JET)\n","        mask_colored = cv2.cvtColor(mask_colored, cv2.COLOR_BGR2RGB)\n","        overlay = cv2.addWeighted(overlay, 0.6, mask_colored, 0.4, 0)\n","        x1, y1, x2, y2 = final_bbox\n","        cv2.rectangle(overlay, (x1, y1), (x2, y2), (0, 255, 0), 3)\n","        axes[0, 2].imshow(overlay)\n","        axes[0, 2]. set_title('Overlay + BBox')\n","        axes[0, 2].axis('off')\n","\n","        # Row 2\n","        axes[1, 0]. imshow(final_roi)\n","        axes[1, 0].set_title('ROI')\n","        axes[1, 0].axis('off')\n","\n","        # Probabilities\n","        sorted_probs = sorted(enumerate(final_probs), key=lambda x: x[1], reverse=True)\n","        top5_classes = [idx_to_class[i] for i, _ in sorted_probs[:5]]\n","        top5_probs = [p for _, p in sorted_probs[: 5]]\n","\n","        axes[1, 1].barh(top5_classes, top5_probs, color='steelblue')\n","        axes[1, 1].set_xlabel('Probability')\n","        axes[1, 1].set_title('Top 5 Predictions')\n","        axes[1, 1].invert_yaxis()\n","\n","        # Summary\n","        axes[1, 2].axis('off')\n","        summary_text = f\"\"\"\n","ADAPTIVE INFERENCE\n","{'='*30}\n","\n","Decision: {decision.upper()}\n","Preprocessing: {preprocessing_used}\n","\n","Baseline:\n","- Conf: {confidence_baseline*100:.1f}%\n","- Pred: {prediction_baseline}\n","\n","Final:\n","- Conf: {final_confidence*100:.1f}%\n","- Pred: {final_prediction}\n","\n","Improvement: {improvement*100:+.1f}%\n","